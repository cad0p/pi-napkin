{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["bun"]
  },
  "include": ["extensions/**/*.ts", "scripts/**/*.ts"],
  "exclude": [
    "extensions/**/*.test.ts",
    "extensions/**/_test-helpers.ts",
    "scripts/**/*.test.ts"
  ]
}
